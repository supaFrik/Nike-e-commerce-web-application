  "nodes": [
    {
      "id": "domain:checkout-orchestration",
      "type": "domain",
      "name": "Checkout Orchestration",
      "summary": "Coordinates authenticated checkout requests from the checkout page through order creation. It validates customer input, shipping choices, owned addresses, and cart availability before choosing the correct payment path.",
      "tags": [
        "checkout",
        "orders",
        "authentication"
      ],
      "complexity": "complex",
      "domainMeta": {
        "entities": [
          "PlaceCheckoutRequest",
          "CheckoutService",
          "CheckoutPageViewService",
          "CheckoutPaymentHandler"
        ],
        "businessRules": [
          "Checkout is available only to authenticated users.",
          "Payment method, shipping method, address ownership, recipient fields, and cart contents are validated before order creation.",
          "VNPay checkout creates a pending-payment order, while COD checkout immediately enters processing."
        ],
        "crossDomainInteractions": [
          "Creates order aggregates in Order State Management.",
          "Reads and clears cart state through Cart and Inventory Integrity.",
          "Delegates VNPay payment URL creation to Payment Processing."
        ]
      }
    },
    {
      "id": "domain:payment-processing",
      "type": "domain",
      "name": "Payment Processing",
      "summary": "Handles VNPay payment initiation and callback reconciliation. It signs gateway requests, records transactions, verifies callback integrity, and moves orders forward or failed based on verified provider result codes.",
      "tags": [
        "payments",
        "vnpay",
        "callbacks"
      ],
      "complexity": "complex",
      "domainMeta": {
        "entities": [
          "PaymentTransaction",
          "VNPayPaymentService",
          "VNPaySignatureService",
          "PaymentStatus"
        ],
        "businessRules": [
          "VNPay URL creation requires an owned VNPAY order in PENDING_PAYMENT status and valid gateway configuration.",
          "Transaction references are unique and expire fifteen minutes after creation.",
          "Callback signatures are HMAC-SHA512 over sorted non-signature fields, and callback amount must match the transaction amount multiplied by 100.",
          "VNPay success requires responseCode=00 and transactionStatus=00."
        ],
        "crossDomainInteractions": [
          "Consumes pending orders from Order State Management.",
          "On successful payment, triggers stock deduction and purchased cart cleanup in Cart and Inventory Integrity.",
          "Exposes public return and IPN endpoints through security configuration."
        ]
      }
    },
    {
      "id": "domain:order-state-management",
      "type": "domain",
      "name": "Order State Management",
      "summary": "Maintains customer-owned order aggregates, immutable item snapshots, payment method, shipping snapshot, totals, and status transitions. It also composes the customer order detail page with payment history, pricing, timeline, and available actions.",
      "tags": [
        "orders",
        "status",
        "snapshots"
      ],
      "complexity": "moderate",
      "domainMeta": {
        "entities": [
          "Order",
          "OrderItem",
          "OrderStatus",
          "OrderRepository",
          "OrderPageViewService"
        ],
        "businessRules": [
          "Order items preserve checkout-time product, variant, SKU, size, color, price, quantity, and line total snapshots.",
          "Orders are scoped to the current authenticated customer for page access and payment initiation.",
          "Payment outcomes transition orders among PENDING_PAYMENT, PROCESSING, and PAYMENT_FAILED."
        ],
        "crossDomainInteractions": [
          "Receives newly created orders from Checkout Orchestration.",
          "Supplies pending VNPay orders to Payment Processing.",
          "Reflects inventory-sensitive checkout results from Cart and Inventory Integrity."
        ]
      }
    },
    {
      "id": "domain:cart-inventory-integrity",
      "type": "domain",
      "name": "Cart and Inventory Integrity",
      "summary": "Protects stock and cart consistency across checkout and payment completion. It reads customer cart items, pessimistically locks variants for stock-sensitive checks, deducts stock at the correct business moment, and clears purchased cart variants.",
      "tags": [
        "cart",
        "inventory",
        "locking"
      ],
      "complexity": "complex",
      "domainMeta": {
        "entities": [
          "CartItem",
          "CartItemRepository",
          "ProductVariantRepository",
          "ProductVariant"
        ],
        "businessRules": [
          "Cart checkout requires at least one cart item.",
          "Variants must be active and have sufficient stock.",
          "Variant rows are pessimistically locked before stock-sensitive validation or deduction.",
          "COD deducts stock and clears the cart immediately; VNPay waits until verified payment success."
        ],
        "crossDomainInteractions": [
          "Provides cart and variant availability data to Checkout Orchestration.",
          "Receives successful VNPay completion events from Payment Processing.",
          "Updates stock and cart state that determine order fulfillment readiness in Order State Management."
        ]
      }
    },
