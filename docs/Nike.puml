@startuml
title Nike Ecommerce Web Application - Current Class Diagram

left to right direction
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam classAttributeIconSize 0
hide empty methods

package "vn.demo.nike" {
  class NikeApplication <<SpringBootApplication>>
}

package "shared" {
  abstract class BaseEntity <<MappedSuperclass>> {
    -id: Long
    -createDate: LocalDateTime
    -updateDate: LocalDateTime
  }

  class SecurityConfig <<Configuration>>
  class GlobalControllerAdvice <<ControllerAdvice>>
  class GlobalExceptionHandler <<RestControllerAdvice>>
  class ErrorResponse <<record>> {
    +status: int
    +message: String
    +timestamp: long
  }
}

package "features.home.api" {
  class HomeController <<Controller>>
}

package "features.admin.api" {
  class AdminPageController <<Controller>>
}

package "features.catalog.category" {
  class Category <<Entity>> {
    -name: String
  }

  interface CategoryRepository <<Repository>> {
    +findAllByOrderByNameAsc()
  }

  class CategoryService <<Service>>

  class CategoryView <<DTO>> {
    -id: Long
    -name: String
  }

  class CategoryNotFoundException <<Exception>>
}

package "features.catalog.product.domain.enums" {
  enum ProductStatus {
    ACTIVE
    DRAFT
    FEW_LEFT
    OUT_OF_STOCK
    DISCONTINUED
  }

  enum InventoryStatus {
    IN_ORDER
    FEW_LEFT
    OUT_OF_STOCK
    DISCONTINUED
  }

  enum ProductBadge {
    BESTSELLER
    NEW_ARRIVAL
    LIMITED_EDITION
    TRENDING
  }
}

package "features.catalog.product.domain" {
  class Product <<Entity>> {
    -name: String
    -description: String
    -type: String
    -price: BigDecimal
    -salePrice: BigDecimal
    -productStatus: ProductStatus
  }

  class ProductColor <<Entity>> {
    -colorName: String
    -hexCode: String
    -displayOrder: Integer
  }

  class ProductImage <<Entity>> {
    -path: String
    -title: String
    -altText: String
    -isMainForColor: Boolean
    -orderIndex: Integer
  }

  class ProductVariant <<Entity>> {
    -sku: String
    -size: String
    -stock: Integer
    -active: Boolean
    -inventoryStatus: InventoryStatus
  }
}

package "features.catalog.product.repository" {
  interface ProductRepository <<Repository>> {
    +findByCategory_Id(id)
    +findByCategory_Id(id, sort)
    +findProductList(categoryId, pageable)
  }

  interface ProductVariantRepository <<Repository>> {
    +findByIdForUpdate(id)
  }
}

